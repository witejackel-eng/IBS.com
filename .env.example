# Copy this file to .env and fill in the values you need. Every variable is
# optional in the sense that the site degrades gracefully without it -- see
# the comment on each one for what stops working when it's unset.

# --- Database (Prisma + PostgreSQL) ---------------------------------------
# Powers persisted contact submissions and the /admin content overrides.
# Without it, the site runs entirely on the static content in src/lib/content
# and contact submissions are delivered by email only.
# DATABASE_URL="postgresql://user:password@localhost:5432/ibs_infra?schema=public"

# --- Email (Resend) --------------------------------------------------------
# Sends a notification email for every contact form submission.
# Without it, submissions are only persisted to the database (if configured).
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# CONTACT_FROM_EMAIL="IBS Website <onboarding@resend.dev>"
# CONTACT_TO_EMAIL="sales@insight-solutions.in"

# --- Admin CMS --------------------------------------------------------------
# Gates access to /admin. Without ADMIN_PASSWORD set, /admin is disabled.
# ADMIN_PASSWORD="choose-a-strong-password"
# ADMIN_SESSION_SECRET="a-long-random-string-used-to-sign-the-session-cookie"

# --- Site ------------------------------------------------------------------
# Used for absolute URLs in metadata, sitemap.xml, and JSON-LD.
# NEXT_PUBLIC_SITE_URL="https://ibsinfra.com"
